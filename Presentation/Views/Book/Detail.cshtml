@model DetailBookVM

<div class="alert alert-info">
    <h4 class="alert-heading">Book Information</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-3">
            <label asp-for="BookName">Name</label>
        </dt>
        <dd class="col-sm-9">
            <span>@Model.BookName</span>
        </dd>
        <dt class="col-sm-3">
            <label asp-for="Description"></label>
        </dt>
        <dd class="col-sm-9">
            <span>@Model.Description</span>
        </dd>
        <dt class="col-sm-3">
            <label asp-for="Author"></label>
        </dt>
        <dd class="col-sm-9">
            <span>@Model.Author</span>
        </dd>
        <dt class="col-sm-3">
            <label asp-for="PageCount"></label>
        </dt>
        <dd class="col-sm-9">
            <span>@Model.PageCount</span>
        </dd>
        <dt class="col-sm-3">
           <label asp-for="CategoryName"></label>
        </dt>
        <dd class="col-sm-9">
           <span>@Model.CategoryName</span>
        </dd>
    </dl>
</div>

<div class="d-flex justify-content-between mt-4">
    <a asp-controller="Book" asp-action="Index" class="btn btn-info btn-lg">Back to Book List</a>
    <a asp-action="Update" asp-route-id="@Model.Id" class="btn btn-primary btn-lg">Edit Book</a>
</div>
