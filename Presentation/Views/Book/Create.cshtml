@using Presentation.Models.ViewModels
@model CreateBookVM

<div class="container  mt-5" style="position:center">
    <h2 class="text-white mb-4">📗 Add New Book</h2>

    <div class="row">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-body">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        <div class="mb-3">
                            <label asp-for="BookName" class="form-label fw-bold">Name</label>
                            <input asp-for="BookName" class="form-control" placeholder="Enter the book name" />
                            <span asp-validation-for="BookName" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Description" class="form-label fw-bold">Description</label>
                            <input asp-for="Description" class="form-control" placeholder="Enter the book description" />
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Author" class="form-label fw-bold">Author</label>
                            <input asp-for="Author" class="form-control" placeholder="Enter the author of the book" />
                            <span asp-validation-for="Author" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="PageCount" class="form-label fw-bold">PageCount</label>
                            <input asp-for="PageCount" type="number" class="form-control" placeholder="Enter the total number of pages in the book" />
                            <span asp-validation-for="PageCount" class="text-danger"></span>
                        </div>
                        <div class="mb-5">
                            <label class="form-label fw-bold">Category</label>
                            <select asp-for="CategoryId" asp-items="@Model.Categories" class="form-select w-100">
                                <option value=""> Select Category </option>
                            </select>
                        </div>
                        <div class="d-flex justify-content-between">
                            <button type="submit" class="btn btn-success px-4">✅ Add Book</button>
                            <a asp-controller="Book" asp-action="Index" class="btn btn-outline-primary">🔙 Back to BookList</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}