@model DetailCategoryVM

@{
    ViewBag.Title = "Delete";
}

<h2 class="text-danger">Delete Category</h2>

<div class="alert alert-danger">
    <h4 class="alert-heading">Are you sure you want to delete @Model.CategoryName ?</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-3">
            <label asp-for="CategoryName">Name</label>
        </dt>
        <dd class="col-sm-9">
            <span>@Model.CategoryName</span>
        </dd>
    </dl>
</div>

<div class="d-flex justify-content-between mt-4">
    <form asp-action="DeleteConfirmed" asp-route-id="@Model.Id" class="d-inline">
        <input type="submit" value="Delete" class="btn btn-danger btn-lg" />
    </form>
    <a asp-controller="Book" asp-action="Index" class="btn btn-info btn-lg">Back to List</a>
</div>