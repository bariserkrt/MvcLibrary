@model DetailCategoryVM

<div class="alert alert-info">
    <h4 class="alert-heading">Category Information</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-3">
            <label asp-for="CategoryName">Category Name</label>
        </dt>
        <dd class="col-sm-9">
            <span>@Model.CategoryName</span>
        </dd>
    </dl>
</div>

    <div class="d-flex justify-content-between mt-4">
        <a asp-action="Index" class="btn btn-info btn-lg">Back to Category List</a>
        <a asp-action="Update" asp-route-id="@Model.Id" class="btn btn-primary btn-lg">Edit the Category</a>
    </div>

